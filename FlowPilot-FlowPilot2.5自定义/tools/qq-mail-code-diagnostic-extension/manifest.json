{
  "manifest_version": 3,
  "name": "QQ邮箱验证码诊断",
  "version": "1.0.0",
  "description": "单独诊断 QQ 邮箱网页中 OpenAI/ChatGPT 验证码识别情况",
  "permissions": [
    "scripting",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://mail.qq.com/*",
    "https://wx.mail.qq.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.qq.com/*",
        "https://wx.mail.qq.com/*"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "QQ邮箱验证码诊断"
  }
}
